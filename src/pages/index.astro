						"text": "No. Unlike cloud storage sharing, your files are never uploaded to any server. This peer to peer file sharing approach eliminates the risks associated with cloud file transfer and storage leaks."
					}
				},
				{
					"@type": "Question",
					"name": "What file types can I share?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "You can share any file type, including document sharing for PDFs/DOCs and media file sharing for large video or audio files. Our file sharing platform is completely format-agnostic."
					}
				}
			]
		}
		</script>
	</div>
</Layout>

<script>
	import { Peer } from 'peerjs';

	const stateReady = document.getElementById('state-ready');
	const stateSelected = document.getElementById('state-selected');
	const stateSharing = document.getElementById('state-sharing');
	const stateReceiving = document.getElementById('state-receiving');
	const fileInput = document.getElementById('file-input');
	const folderInput = document.getElementById('folder-input');
	const fileInputMore = document.getElementById('file-input-more');
	const folderInputMore = document.getElementById('folder-input-more');
	const startShare = document.getElementById('start-share');
	const clearSelected = document.getElementById('clear-selected');
	const selectedSummary = document.getElementById('selected-summary');
	const selectedList = document.getElementById('selected-list');
	const fileInfo = document.getElementById('file-info');
	const sharingStatus = document.getElementById('sharing-status');
	const shareLink = document.getElementById('share-link');
	const copyLink = document.getElementById('copy-link');
	const cancelShare = document.getElementById('cancel-share');
	const receiveInfo = document.getElementById('receive-info');
	const receivingStatus = document.getElementById('receiving-status');
	const downloadContainer = document.getElementById('download-container');
	const progressContainer = document.getElementById('transfer-progress-container');
	const progressBar = document.getElementById('transfer-progress');

	let peer = null;
	let selectedFiles = [];
	let incomingManifest = [];
	let currentTransferIndex = 0;
	let activeConnection = null;

	function showState(state) {
		stateReady.classList.add('hidden');
		stateSelected.classList.add('hidden');
		stateSharing.classList.add('hidden');
		stateReceiving.classList.add('hidden');
		
		if (state === 'ready') stateReady.classList.remove('hidden');
		if (state === 'selected') stateSelected.classList.remove('hidden');
		if (state === 'sharing') stateSharing.classList.remove('hidden');
		if (state === 'receiving') stateReceiving.classList.remove('hidden');
	}

	function initPeer() {
		peer = new Peer({
			config: { 'iceServers': [{ urls: 'stun:stun.l.google.com:19302' }, { urls: 'stun:global.stun.twilio.com:3478?transport=udp' }] }
		});
		
		peer.on('open', (id) => {
			console.log('My peer ID is: ' + id);
			checkUrlForPeer();
		});

		peer.on('connection', (conn) => {
			activeConnection = conn;
			handleConnection(conn);
		});

		peer.on('error', (err) => {
			console.error('Peer error:', err);
			if (err.type === 'peer-unavailable') {
				receivingStatus.innerText = 'Sender is offline or link is invalid.';
			} else if (err.type !== 'disconnected') {
				alert('P2P Error: ' + err.type);
			}
		});
	}

	function checkUrlForPeer() {
		const urlParams = new URLSearchParams(window.location.search);
		const targetId = urlParams.get('peer');
		if (targetId) {
			connectToPeer(targetId);
		}
	}

	function connectToPeer(targetId) {
		showState('receiving');
		receivingStatus.innerText = 'Initializing connection...';
		
		const conn = peer.connect(targetId, { reliable: true });
		activeConnection = conn;
		handleConnection(conn);
	}

	function handleConnection(conn) {
		const setupDataListeners = () => {
			conn.on('data', (data) => {
				if (data.type === 'manifest') {
					incomingManifest = data.files;
					currentTransferIndex = 0;
					receiveInfo.innerText = `Receiving ${incomingManifest.length} items`;
					receivingStatus.innerText = 'Downloading...';
					downloadContainer.innerHTML = '';
					downloadContainer.classList.remove('hidden');
					progressContainer.classList.remove('hidden');
					conn.send({ type: 'pull-file', index: 0 });
				} else if (data.type === 'pull-file') {
					const idx = data.index;
					if (idx < selectedFiles.length) {
						sharingStatus.innerText = `Uploading: ${selectedFiles[idx].name}`;
						progressBar.style.width = `${((idx) / selectedFiles.length) * 100}%`;
						conn.send({
							type: 'file-blob',
							blob: selectedFiles[idx],
							index: idx
						});
					} else {
						sharingStatus.innerText = 'All files transferred successfully.';
						progressBar.style.width = '100%';
					}
				} else if (data.type === 'file-blob') {
					const idx = data.index;
					const meta = incomingManifest[idx];
					const blob = new Blob([data.blob], { type: meta.type });
					const url = URL.createObjectURL(blob);

					const fileRow = document.createElement('div');
					fileRow.className = 'flex items-center justify-between p-sm bg-canvas-soft border border-hairline rounded-md text-body-sm mb-xs';
					fileRow.innerHTML = `
						<span class="truncate max-w-[70%] font-mono text-ink">${meta.name}</span>
						<a href="${url}" download="${meta.name.split('/').pop()}" class="text-primary font-bold hover:underline">Save</a>
					`;
					downloadContainer.appendChild(fileRow);
					downloadContainer.scrollTop = downloadContainer.scrollHeight;

					currentTransferIndex++;
					const percent = (currentTransferIndex / incomingManifest.length) * 100;
					progressBar.style.width = `${percent}%`;
					receiveInfo.innerText = `Progress: ${currentTransferIndex}/${incomingManifest.length}`;
					receivingStatus.innerText = percent === 100 ? 'Transfer Complete!' : 'Downloading...';

					if (currentTransferIndex < incomingManifest.length) {
						conn.send({ type: 'pull-file', index: currentTransferIndex });
					}

					const autoLink = document.createElement('a');
					autoLink.href = url;
					autoLink.download = meta.name.split('/').pop();
					document.body.appendChild(autoLink);
					autoLink.click();
					document.body.removeChild(autoLink);
				}
			});

			conn.on('close', () => {
				console.log('Connection closed');
				if (incomingManifest.length > 0 && currentTransferIndex < incomingManifest.length) {
					receivingStatus.innerText = 'Transfer interrupted.';
				}
			});
		};

		const handleOpen = () => {
			console.log('Connection opened');
			setupDataListeners();
			
			if (selectedFiles.length > 0) {
				sharingStatus.innerText = 'Peer connected. Sending files...';
				progressContainer.classList.remove('hidden');
				conn.send({
					type: 'manifest',
					files: selectedFiles.map(f => ({
						name: f.relativePath || f.webkitRelativePath || f.name,
						size: f.size,
						type: f.type || 'application/octet-stream'
					}))
				});
			} else {
				receivingStatus.innerText = 'Connected. Waiting for files...';
			}
		};

		// Try listening to open event first, this is the most reliable way in PeerJS
		conn.on('open', handleOpen);
		
		// Fallback in case conn is already fully open and open event missed
		setTimeout(() => {
			if (conn.open && !conn._openHandled) {
				conn._openHandled = true;
				handleOpen();
			}
		}, 500);
	}

	function handleFileSelection(files) {
		if (files.length > 0) {
			const existingPaths = new Set(selectedFiles.map(f => f.relativePath || f.webkitRelativePath || f.name));
			files.forEach(file => {
				const path = file.relativePath || file.webkitRelativePath || file.name;
				if (!existingPaths.has(path)) {
					selectedFiles.push(file);
					existingPaths.add(path);
				}
			});
			renderSelectedFiles();
		}
	}

	function renderSelectedFiles() {
		if (selectedFiles.length === 0) {
			showState('ready');
			return;
		}

		selectedList.innerHTML = '';
		selectedFiles.forEach((file, index) => {
			const path = file.relativePath || file.webkitRelativePath || file.name;
			const fileRow = document.createElement('div');
			fileRow.className = 'flex items-center justify-between p-sm bg-canvas border border-hairline rounded-md text-body-sm mb-xs';
			fileRow.innerHTML = `
				<span class="truncate max-w-[80%] font-mono text-ink" title="${path}">${path}</span>
				<button class="text-error hover:opacity-80 p-xs" data-index="${index}">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
			`;
			fileRow.querySelector('button').addEventListener('click', (e) => {
				const idx = parseInt(e.currentTarget.getAttribute('data-index'));
				selectedFiles.splice(idx, 1);
				renderSelectedFiles();
			});
			selectedList.appendChild(fileRow);
		});

		const totalSize = selectedFiles.reduce((acc, f) => acc + f.size, 0);
		selectedSummary.innerText = `${selectedFiles.length} items (${formatBytes(totalSize)})`;
		showState('selected');
	}

	fileInput.addEventListener('change', (e) => handleFileSelection(Array.from(e.target.files)));
	folderInput.addEventListener('change', (e) => handleFileSelection(Array.from(e.target.files)));
	fileInputMore.addEventListener('change', (e) => handleFileSelection(Array.from(e.target.files)));
	folderInputMore.addEventListener('change', (e) => handleFileSelection(Array.from(e.target.files)));

	startShare.addEventListener('click', () => {
		if (selectedFiles.length > 0) {
			const totalSize = selectedFiles.reduce((acc, f) => acc + f.size, 0);
			fileInfo.innerText = `${selectedFiles.length} items (${formatBytes(totalSize)})`;
			
			const url = new URL(window.location.href);
			url.searchParams.set('peer', peer.id);
			shareLink.value = url.toString();
			sharingStatus.innerText = 'Link ready. Waiting for recipient...';
			
			showState('sharing');
		}
	});

	clearSelected.addEventListener('click', () => {
		selectedFiles = [];
		renderSelectedFiles();
	});

	copyLink.addEventListener('click', () => {
		navigator.clipboard.writeText(shareLink.value);
		const originalIcon = copyLink.innerHTML;
		copyLink.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success"><polyline points="20 6 9 17 4 12"></polyline></svg>';
		setTimeout(() => { copyLink.innerHTML = originalIcon; }, 2000);
	});

	cancelShare.addEventListener('click', () => {
		selectedFiles = [];
		if (activeConnection) activeConnection.close();
		showState('ready');
		progressContainer.classList.add('hidden');
		progressBar.style.width = '0%';
		const url = new URL(window.location.href);
		url.searchParams.delete('peer');
		window.history.pushState({}, '', url);
	});

	function formatBytes(bytes, decimals = 2) {
		if (bytes === 0) return '0 Bytes';
		const k = 1024;
		const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];
		const i = Math.floor(Math.log(bytes) / Math.log(k));
		return parseFloat((bytes / Math.pow(k, i)).toFixed(decimals)) + ' ' + sizes[i];
	}

	initPeer();

	const shareBox = document.getElementById('share-box');
	['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
		shareBox.addEventListener(eventName, (e) => { e.preventDefault(); e.stopPropagation(); }, false);
	});

	shareBox.addEventListener('drop', (e) => {
		const items = e.dataTransfer.items;
		if (items) {
			const files = [];
			const scanItems = async (item, path = '') => {
				if (item.isFile) {
					const file = await new Promise(res => item.file(res));
					file.relativePath = path + file.name;
					files.push(file);
				} else if (item.isDirectory) {
					const reader = item.createReader();
					let entries = [];
					const read = async () => {
						const results = await new Promise(res => reader.readEntries(res));
						if (results.length > 0) {
							entries = entries.concat(results);
							await read();
						}
					};
					await read();
					for (const entry of entries) {
						await scanItems(entry, path + item.name + '/');
					}
				}
			};
			
			const promises = [];
			for (const item of items) {
				const entry = item.webkitGetAsEntry();
				if (entry) promises.push(scanItems(entry));
			}
			
			Promise.all(promises).then(() => handleFileSelection(files));
		} else {
			handleFileSelection(Array.from(e.dataTransfer.files));
		}
	});
</script>

