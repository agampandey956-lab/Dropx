---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DropX - Peer-to-peer file sharing">
	<div class="relative min-h-[calc(100vh-64px)] flex flex-col">
		<!-- Mesh Gradient Backdrop -->
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[1400px] h-[600px] -z-10 opacity-30 dark:opacity-20 blur-[100px] pointer-events-none">
			<div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] rounded-full bg-gradient-to-br from-gradient-develop-start to-gradient-develop-end animate-pulse"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[60%] h-[60%] rounded-full bg-gradient-to-br from-gradient-preview-start to-gradient-preview-end animate-pulse" style="animation-delay: -2s"></div>
		</div>

		<section class="flex-grow container py-xl md:py-4xl flex flex-col items-center justify-center text-center">
			<div class="max-w-[800px] w-full">
				<h1 class="text-display-md md:text-display-xl mb-lg text-ink">
					Share files. Peer-to-peer. <br/>
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-gradient-develop-start to-gradient-preview-start">No Cloud. No Limits.</span>
				</h1>
				<p class="text-body-md md:text-body-lg text-body mb-2xl md:mb-3xl max-w-[600px] mx-auto">
					DropX uses WebRTC to send files directly between browsers. Your data never touches our servers.
				</p>

				<!-- Share Box -->
				<div id="share-box" class="bg-canvas rounded-lg border border-hairline p-lg md:p-3xl shadow-soft-stack relative overflow-hidden group mx-auto w-full max-w-[600px]">
					<!-- Progress Bar -->
					<div id="transfer-progress-container" class="absolute top-0 left-0 w-full h-1 bg-canvas-soft-2 hidden">
						<div id="transfer-progress" class="h-full bg-gradient-to-r from-gradient-develop-start to-gradient-preview-end w-0 transition-all duration-300"></div>
					</div>

					<div id="state-ready" class="flex flex-col items-center text-ink">
						<div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-canvas-soft flex items-center justify-center mb-lg md:mb-xl border border-hairline group-hover:scale-110 transition-transform duration-500">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-body">
								<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
							</svg>
						</div>
						<h3 class="text-display-sm mb-sm">Drop anything here</h3>
						<p class="text-body-sm text-body mb-lg md:mb-xl">Files or folders. Direct browser-to-browser.</p>
						<div class="flex flex-col sm:flex-row gap-md">
							<label class="px-xl h-[48px] rounded-pill bg-primary text-on-primary font-medium hover:opacity-90 transition-opacity flex items-center justify-center cursor-pointer shadow-sm">
								Select Files
								<input type="file" id="file-input" class="hidden" multiple />
							</label>
							<label class="px-xl h-[48px] rounded-pill bg-canvas-soft border border-hairline text-ink font-medium hover:bg-canvas transition-colors flex items-center justify-center cursor-pointer">
								Select Folder
								<input type="file" id="folder-input" class="hidden" webkitdirectory />
							</label>
						</div>
					</div>

					<div id="state-selected" class="hidden flex flex-col items-center text-ink w-full">
						<div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-canvas-soft flex items-center justify-center mb-lg md:mb-xl border border-hairline group-hover:scale-110 transition-transform duration-500">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-body animate-pulse">
								<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
							</svg>
						</div>
						<h3 class="text-display-sm mb-sm">Selected items</h3>
						<p id="selected-summary" class="text-body-sm text-body mb-lg font-mono">0 items (0 Bytes)</p>
						
						<!-- List of selected files -->
						<div id="selected-list" class="w-full bg-canvas-soft border border-hairline rounded-md p-md max-h-[160px] overflow-y-auto mb-lg text-left custom-scrollbar flex flex-col gap-xs">
							<!-- Selected files list injected here -->
						</div>

						<div class="flex flex-col sm:flex-row gap-md w-full justify-center mb-lg">
							<label class="px-lg h-[40px] rounded-pill bg-canvas-soft border border-hairline text-ink text-body-sm font-medium hover:bg-canvas transition-colors flex items-center justify-center cursor-pointer">
								Add Files
								<input type="file" id="file-input-more" class="hidden" multiple />
							</label>
							<label class="px-lg h-[40px] rounded-pill bg-canvas-soft border border-hairline text-ink text-body-sm font-medium hover:bg-canvas transition-colors flex items-center justify-center cursor-pointer">
								Add Folder
								<input type="file" id="folder-input-more" class="hidden" webkitdirectory />
							</label>
						</div>
						
						<button id="start-share" class="w-full h-[48px] rounded-pill bg-primary text-on-primary font-medium hover:opacity-90 transition-opacity flex items-center justify-center shadow-sm">
							Generate Share Link
						</button>
						<button id="clear-selected" class="mt-lg text-body-sm text-error hover:underline">Clear all</button>
					</div>

					<div id="state-sharing" class="hidden flex flex-col items-center text-ink">
						<div class="w-16 h-16 rounded-full bg-canvas-soft flex items-center justify-center mb-lg border border-hairline animate-pulse">
							<div class="w-3 h-3 rounded-full bg-cyan animate-ping"></div>
						</div>
						<h3 class="text-display-sm mb-sm">Ready to share</h3>
						<p id="file-info" class="text-body-sm text-body mb-xl font-mono truncate max-w-full px-lg">0 files (0 Bytes)</p>
						
						<div class="w-full bg-canvas-soft-2 border border-hairline rounded-md p-md flex items-center gap-md mb-lg">
							<input type="text" id="share-link" readonly class="bg-transparent border-none text-body-sm font-mono flex-grow focus:outline-none text-ink" />
							<button id="copy-link" class="p-xs hover:bg-canvas rounded transition-colors text-body">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
							</button>
						</div>
						<p id="sharing-status" class="text-body-sm-strong text-primary mb-md">Waiting for recipient...</p>
						<p class="text-caption text-mute">Send this link to the recipient. Keep this page open.</p>
						<button id="cancel-share" class="mt-xl text-body-sm text-error hover:underline">Cancel</button>
					</div>

					<div id="state-receiving" class="hidden flex flex-col items-center text-ink">
						<div class="w-16 h-16 rounded-full bg-canvas-soft flex items-center justify-center mb-lg border border-hairline">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-body animate-bounce">
								<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
							</svg>
						</div>
						<h3 class="text-display-sm mb-sm">Incoming transfer</h3>
						<p id="receive-info" class="text-body-sm text-body mb-xl font-mono">Connecting...</p>
						<div id="receiving-status" class="text-body-sm-strong text-primary mb-xl">Connecting to peer...</div>
						<div id="download-container" class="hidden flex flex-col gap-sm w-full max-h-[200px] overflow-y-auto mb-xl px-2 custom-scrollbar">
							<!-- Download links injected here -->
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="features" class="container py-xl md:py-section">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-lg md:gap-xl">
				<div class="p-lg md:p-xl bg-canvas border border-hairline rounded-md">
					<div class="w-10 h-10 rounded bg-canvas-soft flex items-center justify-center mb-lg border border-hairline text-ink">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					</div>
					<h4 class="text-display-sm mb-sm text-ink">End-to-End Private</h4>
					<p class="text-body-sm text-body">Your files are encrypted and sent directly. No one, not even us, can see your data.</p>
				</div>
				<div class="p-lg md:p-xl bg-canvas border border-hairline rounded-md">
					<div class="w-10 h-10 rounded bg-canvas-soft flex items-center justify-center mb-lg border border-hairline text-ink">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
					</div>
					<h4 class="text-display-sm mb-sm text-ink">Blazing Fast</h4>
					<p class="text-body-sm text-body">Transfers happen at your maximum network speed. No cloud throttles or upload waits.</p>
				</div>
				<div class="p-lg md:p-xl bg-canvas border border-hairline rounded-md">
					<div class="w-10 h-10 rounded bg-canvas-soft flex items-center justify-center mb-lg border border-hairline text-ink">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
					</div>
					<h4 class="text-display-sm mb-sm text-ink text-left">No Size Limits</h4>
					<p class="text-body-sm text-body">Share 1MB or 100GB. Since we don't store your files, we don't care how big they are.</p>
				</div>
			</div>
		</section>

		<!-- SEO Content Section -->
		<section class="container py-2xl border-t border-hairline">
			<details class="max-w-[900px] mx-auto group">
				<summary class="text-display-sm text-ink cursor-pointer list-none flex items-center gap-2 hover:opacity-80 transition-opacity">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
					Learn More About DropX & Peer-to-Peer File Sharing
				</summary>
				<div class="mt-xl prose dark:prose-invert max-w-none">
					<h2 class="text-display-md mb-xl text-ink">The Ultimate Peer-to-Peer File Sharing Experience</h2>
					
					<p class="text-body-md text-body mb-lg">
						In today's digital age, <strong>file sharing</strong> has become an essential part of our daily lives. Whether you're a professional needing <strong>secure file sharing</strong> for sensitive documents or a casual user looking for <strong>online file sharing</strong> to send photos to friends, finding a reliable <strong>file sharing platform</strong> is crucial. DropX offers a revolutionary approach to <strong>online file transfer</strong> by utilizing <strong>peer to peer file sharing</strong> technology.
					</p>

					<h3 class="text-display-sm mb-md text-ink">Secure and Encrypted File Sharing</h3>
					<p class="text-body-md text-body mb-lg">
						Security is our top priority. Unlike traditional <strong>cloud file sharing</strong> services that store your data on their servers, DropX ensures <strong>encrypted file sharing</strong> by creating a direct link between the sender and the recipient. This <strong>secure file transfer</strong> method means your <strong>private file sharing</strong> remains truly private. With <strong>encrypted file transfer</strong>, you can <strong>share documents online</strong> or <strong>share videos online</strong> without worrying about unauthorized access.
					</p>

					<h3 class="text-display-sm mb-md text-ink">Fast File Transfer for Large Files</h3>
					<p class="text-body-md text-body mb-lg">
						Stop waiting for slow <strong>file upload</strong> speeds. DropX provides <strong>fast file transfer</strong> by bypassing intermediate servers. This <strong>high speed file transfer</strong> is perfect for <strong>large file transfer</strong> tasks, allowing you to <strong>send large files</strong> that other <strong>file hosting</strong> services might reject. Our <strong>unlimited file sharing</strong> capability means you can handle even the most demanding <strong>digital file sharing</strong> needs with ease.
					</p>

					<h3 class="text-display-sm mb-md text-ink">Simple and Easy File Transfer</h3>
					<p class="text-body-md text-body mb-lg">
						We believe in <strong>simple file sharing</strong>. Our <strong>web based file sharing</strong> tool features a <strong>drag and drop file upload</strong> interface, making it an <strong>easy file transfer</strong> solution for everyone. There's no need to install a <strong>file sharing app</strong>; DropX is a <strong>browser-based file sharing</strong> service that works across all devices. This <strong>cross-platform file sharing</strong> flexibility ensures seamless <strong>document sharing</strong> and <strong>media file sharing</strong>.
					</p>

					<h3 class="text-display-sm mb-md text-ink">Business and Team Collaboration</h3>
					<p class="text-body-md text-body mb-lg">
						For professionals, DropX serves as a powerful <strong>business file sharing</strong> and <strong>team file sharing</strong> tool. Whether you're looking for <strong>secure document sharing</strong> for <strong>enterprise file sharing</strong> or <strong>collaborative file sharing</strong> for your creative team, our <strong>data sharing platform</strong> is designed to scale. It functions as a <strong>file management system</strong> without the overhead of traditional <strong>online document management</strong> software, facilitating <strong>business document sharing</strong> and <strong>team file collaboration</strong> efficiently.
					</p>

					<h3 class="text-display-sm mb-md text-ink">Anonymous and Temporary File Sharing</h3>
					<p class="text-body-md text-body mb-lg">
						Sometimes you need <strong>anonymous file sharing</strong>. DropX provides a <strong>temporary file sharing</strong> solution where no accounts are required. Your <strong>file exchange</strong> is direct and ephemeral. If you need extra protection, you can even use <strong>password protected file sharing</strong>. Our <strong>file delivery service</strong> is built on the principles of <strong>secure data transfer</strong> and <strong>private file sharing</strong>.
					</p>

					<h3 class="text-display-sm mb-md text-ink">Why Choose DropX Over Cloud Storage?</h3>
					<p class="text-body-md text-body mb-lg">
						While <strong>cloud storage sharing</strong> and <strong>online storage platforms</strong> have their place, they often involve <strong>cloud file transfer</strong> delays and privacy concerns. DropX is a <strong>file sharing service</strong> that prioritizes <strong>instant file sharing</strong>. By using <strong>remote file sharing</strong> via WebRTC, we offer a <strong>data transfer service</strong> that is more secure than traditional <strong>secure cloud storage</strong>. It's the perfect <strong>file synchronization</strong> and <strong>file distribution</strong> alternative for those who value speed and privacy.
					</p>

					<p class="text-body-md text-body">
						Whether you need to <strong>share photos online</strong>, <strong>upload and share files</strong>, or find a <strong>file backup and sharing</strong> alternative, DropX is your go-to <strong>file sharing software</strong>. Experience <strong>cloud collaboration</strong> without the cloud. Start your <strong>file access management</strong> journey with the most secure <strong>digital file sharing</strong> tool available today. <strong>Transfer files securely</strong> and enjoy <strong>browser-based file sharing</strong> at its finest.
					</p>
				</div>
			</details>
		</section>

		<section id="faq" class="container py-2xl border-t border-hairline">
			<div class="max-w-[900px] mx-auto">
				<h2 class="text-display-md mb-xl text-ink">Frequently Asked Questions</h2>
				
				<div class="space-y-4">
					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							How do I share files online for free?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">To <strong>share files online</strong> for free with DropX, simply select or drag your file into the share box. We provide an <strong>instant file sharing</strong> link that you can send to anyone for a direct, <strong>browser-based file sharing</strong> experience.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							What is the limit for large file transfers on DropX?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">Unlike <strong>cloud file sharing</strong> services, DropX has no hard <strong>file upload</strong> limits. Because we use <strong>peer to peer file sharing</strong>, you can perform a <strong>large file transfer</strong> of any size (even 100GB+) as long as your browser and device can handle it.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							Is browser-based file sharing safe?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">Yes, DropX provides <strong>secure file sharing</strong> by using WebRTC, which includes mandatory <strong>encrypted file sharing</strong>. Your <strong>private file sharing</strong> remains between you and the recipient; your data never touches our servers.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							Do I need an account for anonymous file sharing?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">No. DropX is designed for <strong>anonymous file sharing</strong>. You can <strong>share files online</strong> without creating an account or providing any personal information, ensuring a truly <strong>private file sharing</strong> session.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							How fast is the file transfer speed?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">Our <strong>fast file transfer</strong> is only limited by your internet connection. Since it is a <strong>secure file transfer</strong> happening directly between browsers, there are no middle-man servers to throttle your <strong>online file transfer</strong> speed.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							Can I use DropX for business file sharing?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">Absolutely. Many professionals use DropX for <strong>business file sharing</strong> and <strong>team file collaboration</strong>. It is an ideal <strong>data sharing platform</strong> for sending large assets like high-res videos or CAD files without the cost of <strong>enterprise file sharing</strong> tools.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							Does DropX support mobile file sharing?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">Yes, DropX is a <strong>cross-platform file sharing</strong> tool. You can <strong>share files online</strong> from your mobile browser to a desktop, or vice-versa, making <strong>digital file sharing</strong> easy across all your devices.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							How long do shared links last?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">As a <strong>temporary file sharing</strong> service, links are only active as long as the sender's browser window remains open. Once closed, the <strong>file transfer</strong> session ends, which is a key feature of our <strong>secure data transfer</strong> model.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							Is my data stored in the cloud?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">No. Unlike <strong>cloud storage sharing</strong>, your files are never uploaded to any server. This <strong>peer to peer file sharing</strong> approach eliminates the risks associated with <strong>cloud file transfer</strong> and storage leaks.</p>
					</details>

					<details class="p-lg bg-canvas border border-hairline rounded-md group text-ink">
						<summary class="text-body-md-strong cursor-pointer list-none flex items-center justify-between">
							What file types can I share?
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</summary>
						<p class="text-body-sm text-body mt-lg">You can share any file type, including <strong>document sharing</strong> for PDFs/DOCs and <strong>media file sharing</strong> for large video or audio files. Our <strong>file sharing platform</strong> is completely format-agnostic.</p>
					</details>
				</div>
			</div>
		</section>

		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "How do I share files online for free?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "To share files online for free with DropX, simply select or drag your file into the share box. We provide an instant file sharing link that you can send to anyone for a direct, browser-based file sharing experience."
					}
				},
				{
					"@type": "Question",
					"name": "What is the limit for large file transfers on DropX?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Unlike cloud file sharing services, DropX has no hard file upload limits. Because we use peer to peer file sharing, you can perform a large file transfer of any size (even 100GB+) as long as your browser and device can handle it."
					}
				},
				{
					"@type": "Question",
