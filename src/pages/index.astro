				{
					"@type": "Question",
					"name": "How long do shared links last?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "As a temporary file sharing service, links are only active as long as the sender's browser window remains open. Once closed, the file transfer session ends, which is a key feature of our secure data transfer model."
					}
				},
				{
					"@type": "Question",
					"name": "Is my data stored in the cloud?",
					"acceptedAnswer": {
