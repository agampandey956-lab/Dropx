---
---
<footer class="bg-canvas border-t border-hairline py-12 md:py-24">
  <div class="container">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-xl mb-4xl">
      <div class="col-span-2">
        <a href="/" class="flex items-center gap-xs mb-lg">
          <div class="w-6 h-6 bg-primary rounded flex items-center justify-center">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-on-primary">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <span class="text-body-md-strong tracking-tight text-ink">DropX</span>
        </a>
        <p class="text-body-sm text-body max-w-[240px]">
          Peer-to-peer file sharing for the modern web. Fast, private, and no cloud involved.
        </p>
      </div>
      
      <div>
        <h4 class="text-caption-mono uppercase tracking-widest text-ink mb-lg">Product</h4>
        <ul class="space-y-sm">
          <li><a href="#features" class="text-body-sm text-body hover:text-ink transition-colors">Features</a></li>
          <li><a href="#faq" class="text-body-sm text-body hover:text-ink transition-colors">FAQ</a></li>
          <li><a href="/about" class="text-body-sm text-body hover:text-ink transition-colors">About Us</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-caption-mono uppercase tracking-widest text-ink mb-lg">Resources</h4>
        <ul class="space-y-sm">
          <li><a href="#" class="text-body-sm text-body hover:text-ink transition-colors">Documentation</a></li>
          <li><a href="#" class="text-body-sm text-body hover:text-ink transition-colors">GitHub</a></li>
          <li><a href="/contact" class="text-body-sm text-body hover:text-ink transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-caption-mono uppercase tracking-widest text-ink mb-lg">Legal</h4>
        <ul class="space-y-sm">
          <li><a href="/terms" class="text-body-sm text-body hover:text-ink transition-colors">Terms</a></li>
          <li><a href="/privacy" class="text-body-sm text-body hover:text-ink transition-colors">Privacy</a></li>
        </ul>
      </div>
    </div>
    
    <div class="flex flex-col md:flex-row justify-between items-center pt-xl border-t border-hairline gap-lg">
      <p class="text-caption text-mute">
        &copy; {new Date().getFullYear()} DropX. Designed with passion.
      </p>
    </div>
  </div>
</footer>
