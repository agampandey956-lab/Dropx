---
import ThemeToggle from './ThemeToggle.astro';
---
<header class="sticky top-0 z-50 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline">
  <div class="container h-[64px] flex items-center justify-between">
    <div class="flex items-center gap-md md:gap-xl">
      <a href="/" class="flex items-center gap-xs">
        <div class="w-8 h-8 bg-primary rounded-md flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-on-primary">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="text-display-sm tracking-tight font-bold text-ink truncate">DropX</span>
      </a>
      <nav class="hidden lg:flex items-center gap-md">
        <a href="#features" class="text-body-sm text-body hover:text-ink transition-colors">Features</a>
        <a href="#faq" class="text-body-sm text-body hover:text-ink transition-colors">FAQ</a>
        <a href="/contact" class="text-body-sm text-body hover:text-ink transition-colors">Contact</a>
        <a href="/privacy" class="text-body-sm text-body hover:text-ink transition-colors">Privacy</a>
        <a href="/terms" class="text-body-sm text-body hover:text-ink transition-colors">Terms</a>
      </nav>
    </div>
    
    <div class="flex items-center gap-sm md:gap-md">
      <ThemeToggle />
      <a href="https://github.com" class="hidden sm:flex items-center justify-center p-xs rounded-full hover:bg-canvas-soft transition-colors border border-hairline text-body">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
      </a>
      <a href="/" class="px-sm h-8 rounded-sm bg-primary text-on-primary text-body-sm-strong hover:opacity-90 transition-opacity flex items-center justify-center whitespace-nowrap">
        Start Sharing
      </a>
    </div>
  </div>
</header>
